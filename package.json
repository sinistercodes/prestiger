{
  "name": "dbd-prestiger",
  "version": "2.0.0",
  "description": "DBD Prestige Automator",
  "author": "sin",
  "main": "main.js",
  "scripts": {
    "dev:renderer": "cd renderer && npx vite --port 5173",
    "dev": "npx concurrently -k \"npm run dev:renderer\" \"npx wait-on http://localhost:5173 && electron .\"",
    "start": "electron .",
    "build:renderer": "cd renderer && npm run build",
    "build": "npm run build:renderer && electron-builder --win"
  },
  "build": {
    "appId": "com.dbdprestiger.app",
    "productName": "prestiger",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "win": {
      "icon": "src/assets/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "data/**/*",
      "renderer/dist/**/*",
      "!renderer/src/**",
      "!renderer/node_modules/**",
      "!renderer/tsconfig*",
      "!renderer/vite.config*",
      "!renderer/postcss*",
      "!renderer/tailwind*",
      "!renderer/index.html",
      "!renderer/package.json",
      "!**/*.ts",
      "!**/*.map"
    ]
  },
  "dependencies": {
    "axios": "^0.27.2",
    "discord-rpc": "^4.0.1",
    "node-forge": "^1.3.3",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^9.0.4"
  }
}
